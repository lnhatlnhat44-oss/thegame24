<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Shop</title>
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro&display=swap" rel="stylesheet">
<style>
body{font-family:'Be Vietnam Pro';background:#1e1e2f;color:white;text-align:center}
.card{background:rgba(255,255,255,0.1);padding:15px;margin:10px;border-radius:10px;display:inline-block}
button{padding:5px 10px;border:none;border-radius:5px;cursor:pointer}
</style>
</head>
<body>

<h2>SHOP THẺ</h2>
<a href="checkout.html">🛒 Đi thanh toán</a>

<div class="card">
<h3>Thẻ Garena 50K</h3>
<p>Giá: 45.000đ</p>
<button onclick="add()">+</button>
<button onclick="minus()">-</button>
<span id="qty">1</span>
<button onclick="buy()">Mua</button>
</div>

<script>
let qty=1;
function add(){qty++;document.getElementById("qty").innerText=qty;}
function minus(){if(qty>1)qty--;document.getElementById("qty").innerText=qty;}

function buy(){
localStorage.setItem("order",JSON.stringify({
type:"Garena 50K",
qty:qty,
price:45000
}));
window.location="checkout.html";
}
</script>

</body>
</html>
